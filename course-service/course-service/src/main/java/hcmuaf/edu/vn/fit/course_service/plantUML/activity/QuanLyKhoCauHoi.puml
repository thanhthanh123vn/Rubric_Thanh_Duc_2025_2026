@startuml
skinparam style strictuml
skinparam activity {
  BackgroundColor White
  BorderColor #2c3e50
}

|Người quản trị|
start
:Đăng nhập hệ thống;
:Truy cập menu "Quản lý môn học";

|Hệ thống|
:Lấy danh sách môn học [GET /course];
:Hiển thị danh sách;

|Người quản trị|
if (Chọn thao tác?) then (Thêm mới)
  :Nhập thông tin môn học;
  |Hệ thống|
  :Validate thông tin;
  :Lưu vào CSDL [POST /course/create];
elseif (Chỉnh sửa)
  |Người quản trị|
  :Chọn môn học cần sửa;
  :Cập nhật thông tin;
  |Hệ thống|
  :Lưu thay đổi [PUT /course/{id}];
else (Xóa)
  |Người quản trị|
  :Chọn môn học cần xóa;
  :Xác nhận xóa;
  |Hệ thống|
  :Xóa môn học [DELETE /course/{id}];
endif

|Hệ thống|
if (Thao tác thành công?) then (Có)
  :Hiển thị thông báo thành công;
  :Tải lại danh sách môn học;
else (Không)
  :Hiển thị thông báo lỗi;
endif

|Người quản trị|
stop
@enduml